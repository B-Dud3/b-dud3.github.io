---
import { getCollection, render } from 'astro:content';
import { Image } from 'astro:assets';
import BaseLayout from '../../layouts/BaseLayout.astro';
import SiteFooter from '../../components/SiteFooter.astro';
import { url } from '../../utils/paths';

export async function getStaticPaths() {
  const projects = await getCollection('projects');
  return projects.map((project) => ({
    params: { slug: project.id },
    props: { project },
  }));
}

const { project } = Astro.props;
const { Content } = await render(project);
---
<BaseLayout title={`${project.data.title} — Brandon LiWang`} description={project.data.summary}>
  <nav class="container topbar">
    <a href={url('/')}>← Brandon LiWang</a>
  </nav>
  <main class="container section">
    <article class="prose">
      <h1>{project.data.title}</h1>
      <div class="tags">
        {project.data.tags.map((tag) => <span class="tag">{tag}</span>)}
      </div>
      <Image
        class="hero-image"
        src={project.data.cover}
        alt={project.data.coverAlt}
        widths={[720, 1200]}
        sizes="(max-width: 760px) 100vw, 720px"
      />
      {project.data.github && <p><a href={project.data.github}>View on GitHub</a></p>}
      {project.data.demo && <p><a href={project.data.demo}>Live demo</a></p>}
      <Content />
      <p><a href={url('/#projects')}>← Back to all projects</a></p>
    </article>
  </main>
  <SiteFooter />
</BaseLayout>

<style>
  .topbar { padding: 1.25rem; font-weight: 600; }
  .topbar a { text-decoration: none; }
  .tags { margin-bottom: 1.25rem; }
  .hero-image { border-radius: var(--radius); }
</style>
