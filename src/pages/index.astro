---
import BaseLayout from '../layouts/BaseLayout.astro';
import SiteHeader from '../components/SiteHeader.astro';
import Hero from '../components/Hero.astro';
import ProjectCard from '../components/ProjectCard.astro';
import SkillsSection from '../components/SkillsSection.astro';
import ExperienceSection from '../components/ExperienceSection.astro';
import SiteFooter from '../components/SiteFooter.astro';
import { getPublishedProjects } from '../utils/projects';

const projects = await getPublishedProjects();
---
<BaseLayout
  title="Brandon LiWang — Mechanical Engineer"
  description="Portfolio of Brandon LiWang: autonomous sensing platforms, robotics, and embedded systems. UC Berkeley Mechanical Engineering."
>
  <SiteHeader />
  <Hero />
  <main>
    <section class="container section" id="projects">
      <h2 class="section-title">Projects</h2>
      <div class="grid">
        {projects.map((project) => <ProjectCard project={project} />)}
      </div>
    </section>
    <ExperienceSection />
    <SkillsSection />
  </main>
  <SiteFooter />
</BaseLayout>
