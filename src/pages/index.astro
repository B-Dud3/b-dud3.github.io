---
import BaseLayout from '../layouts/BaseLayout.astro';
import SiteHeader from '../components/SiteHeader.astro';
import Hero from '../components/Hero.astro';
import ProjectCard from '../components/ProjectCard.astro';
import SkillsSection from '../components/SkillsSection.astro';
import ExperienceSection from '../components/ExperienceSection.astro';
import SiteFooter from '../components/SiteFooter.astro';
import { getPublishedProjects } from '../utils/projects';
import { site } from '../data/site';

const projects = await getPublishedProjects();

const personSchema = {
  '@context': 'https://schema.org',
  '@type': 'Person',
  name: site.name,
  url: 'https://b-dud3.github.io/Personal-Website/',
  jobTitle: 'Mechanical Engineer',
  affiliation: { '@type': 'CollegeOrUniversity', name: 'University of California, Berkeley' },
  sameAs: [site.github, site.linkedin],
  knowsAbout: ['Robotics', 'Autonomous systems', 'Mechanical design', 'Machine learning'],
};
---
<BaseLayout
  title="Brandon LiWang — Mechanical Engineer, Robotics & Autonomous Systems"
  description="Portfolio of Brandon LiWang: robotics, autonomous sensing platforms, and embedded systems. UC Berkeley Mechanical Engineering."
  schema={personSchema}
>
  <SiteHeader />
  <Hero />
  <main>
    <section class="container section" id="projects">
      <h2 class="section-title">Projects</h2>
      <div class="grid">
        {projects.map((project) => <ProjectCard project={project} />)}
      </div>
    </section>
    <ExperienceSection />
    <SkillsSection />
  </main>
  <SiteFooter />
</BaseLayout>
