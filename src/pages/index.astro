---
import { getCollection } from 'astro:content';
import BaseLayout from '../layouts/BaseLayout.astro';
import Hero from '../components/Hero.astro';
import ProjectCard from '../components/ProjectCard.astro';
import SkillsSection from '../components/SkillsSection.astro';
import ExperienceSection from '../components/ExperienceSection.astro';
import SiteFooter from '../components/SiteFooter.astro';

const projects = (await getCollection('projects')).sort(
  (a, b) =>
    Number(b.data.featured) - Number(a.data.featured) ||
    b.data.date.valueOf() - a.data.date.valueOf()
);
---
<BaseLayout
  title="Brandon LiWang — Mechanical Engineer"
  description="Portfolio of Brandon LiWang: autonomous sensing platforms, robotics, and embedded systems. UC Berkeley Mechanical Engineering."
>
  <Hero />
  <main>
    <section class="container section" id="projects">
      <h2 class="section-title">Projects</h2>
      <div class="grid">
        {projects.map((project) => <ProjectCard project={project} />)}
      </div>
    </section>
    <SkillsSection />
    <ExperienceSection />
  </main>
  <SiteFooter />
</BaseLayout>
